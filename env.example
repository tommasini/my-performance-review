# ===========================================
# Performance Review AI - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# ===========================================
# AI API Keys (Server-side only)
# ===========================================

# Primary AI Provider - Anthropic Claude (REQUIRED)
# Get your key at: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-api03-YOUR-KEY-HERE

# Fallback AI Provider - OpenAI (Optional but recommended)
# Get your key at: https://platform.openai.com/api-keys
# Used when Claude is overloaded or rate limited
OPENAI_API_KEY=sk-YOUR-OPENAI-KEY-HERE

# Second Fallback AI Provider - DeepSeek (Optional, very affordable)
# Get your key at: https://platform.deepseek.com
# Pricing: ~$0.14/M input tokens (very cheap!)
DEEPSEEK_API_KEY=sk-YOUR-DEEPSEEK-KEY-HERE

# ===========================================
# Rate Limiting
# ===========================================

# Redis URL for distributed rate limiting (Optional)
# If not set, falls back to in-memory rate limiting
# Format: redis://[[username][:password]@][host][:port][/db-number]
# For Upstash: Use Redis connection string from dashboard (rediss://default:PASSWORD@HOST:6379)
# TLS is automatically enabled for Upstash connections
REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://default:YOUR_PASSWORD@your-redis.upstash.io:6379

# Maximum AI generations per minute (per IP)
# Default: 15
RATE_LIMIT_REQUESTS_PER_MINUTE=15

# Maximum AI generations per day (per IP)
# Default: 60
RATE_LIMIT_REQUESTS_PER_DAY=60

# ===========================================
# Security Notes
# ===========================================
# 
# 1. API keys are ONLY used server-side in API routes
# 2. Keys are NEVER exposed to the client/browser
# 3. Rate limiting prevents abuse of your API credits
# 4. Users can optionally provide their own API keys
#    for unlimited access (their keys are also secure)
#
# For production deployment:
# - Set these values in Vercel Environment Variables
#   or your hosting provider's secrets management
# - Use encrypted secrets, not plain text in .env files
# - Run Redis for production-grade rate limiting
# ===========================================

# ===========================================
# Docker Quick Start (for Redis)
# ===========================================
# 
# To start Redis locally:
#   docker-compose up -d redis
#
# To stop:
#   docker-compose down
#
# Redis data is persisted in a Docker volume
# ===========================================
